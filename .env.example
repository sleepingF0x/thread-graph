# ── Telegram ─────────────────────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic API key for summaries, topic naming, and jargon extraction
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings ───────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint. Default points to OpenAI; change to Ollama/etc.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Database ─────────────────────────────────────────────────────────────────
# asyncpg DSN — matches the postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://threadgraph:threadgraph@postgres:5432/threadgraph

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Misc ─────────────────────────────────────────────────────────────────────
# Path for the Telegram session file (relative to backend/)
SESSION_PATH=session/threadgraph
