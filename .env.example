# Telegram API credentials
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Anthropic-compatible LLM endpoint
ANTHROPIC_API_KEY=
# Leave empty to use the official Anthropic API endpoint
ANTHROPIC_BASE_URL=
LLM_MODEL=claude-sonnet-4-6

# Embedding endpoint
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Infrastructure
DATABASE_URL=postgresql+asyncpg://threadgraph:threadgraph@postgres:5432/threadgraph
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Telegram session file path inside the backend container
SESSION_PATH=session/threadgraph
